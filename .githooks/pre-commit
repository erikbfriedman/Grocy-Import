#!/bin/bash
# Auto-increment patch version in grocy-import/config.yaml before every commit.
# Install: git config core.hooksPath .githooks

CONFIG="grocy-import/config.yaml"

if [ ! -f "$CONFIG" ]; then
    exit 0
fi

CURRENT=$(grep '^version:' "$CONFIG" | sed 's/version: "\(.*\)"/\1/')

if [ -z "$CURRENT" ]; then
    exit 0
fi

IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"
PATCH=$((PATCH + 1))
# HA compares versions as strings; keep patch < 10 so "1.3.9" never beats "1.3.10"
if [ "$PATCH" -ge 10 ]; then
    MINOR=$((MINOR + 1))
    PATCH=0
fi
NEW="$MAJOR.$MINOR.$PATCH"

sed -i "s/version: \"$CURRENT\"/version: \"$NEW\"/" "$CONFIG"
git add "$CONFIG"

echo "  version $CURRENT → $NEW"
